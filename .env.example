# Copy to `.env` and fill in keys for the providers you want to use.
# Model strings are LiteLLM ids (see `ncorridor models`); each provider reads its own key.

# Google Gemini  -> models like  gemini/gemini-2.0-flash
GEMINI_API_KEY=

# Anthropic Claude -> models like  anthropic/claude-opus-4-8
ANTHROPIC_API_KEY=

# OpenAI GPT -> models like  openai/gpt-4o
OPENAI_API_KEY=

# OpenRouter (Qwen and many others) -> models like  openrouter/qwen/qwen-2.5-72b-instruct
OPENROUTER_API_KEY=
